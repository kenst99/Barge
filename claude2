    body.dark-mode {
        --bg: #0f172a; --panel: #1e293b;
        --text-main: #f1f5f9; --text-sub: #94a3b8;
        --border: #334155; --card-bg: #1e293b;
        --input-bg: #334155; --cargo-header: #334155;
        --module-bg: #162032; --clock-bg: #1e3a5f; --clock-color: #93c5fd;
        --upload-bg: #162032; --log-header-bg: #1e3a5f;
        --stat-bg: #1e293b; --stat-border: #3b82f6;
        --profit-bg: #064e3b; --profit-border: #10b981;
    }

    body { 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        background: var(--bg); color: var(--text-main); 
        margin: 0; padding: 20px; font-size: 15px; 
        transition: background 0.3s, color 0.3s;
    }

    .container { max-width: 1450px; margin: auto; background: var(--panel); padding: 25px; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
    .header-area { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid var(--border); padding-bottom: 10px; }
    #live-clock { font-weight: bold; color: var(--clock-color); background: var(--clock-bg); padding: 10px 20px; border-radius: 20px; font-size: 16px; }
    
    .top-controls { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 20px; }
    .card-mini { background: var(--module-bg); border: 1px solid var(--border); padding: 15px; border-radius: 10px; }
    .card-mini .label { font-size: 13px; font-weight: bold; color: var(--secondary); text-transform: uppercase; margin-bottom: 8px; display: block; }

    .split-layout { display: flex; gap: 25px; align-items: stretch; margin-bottom: 25px; }
    .col-50 { flex: 1; width: 50%; display: flex; flex-direction: column; gap: 20px; }

    canvas { background: transparent; border-radius: 12px; width: 100%; border: 1px solid var(--border); display: block; margin: 0 auto 20px; }

    .side-panel { background: var(--module-bg); border-radius: 12px; border: 1px solid var(--border); padding: 20px; height: 100%; box-sizing: border-box; }
    .row-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px dashed var(--border); font-size: 15px; }
    .row-item .left-info { flex: 1; color: var(--text-sub); font-weight: 600; text-align: left; }
    .row-item .right-value { flex: 0 0 auto; text-align: right; font-weight: 800; color: var(--text-main); min-width: 140px; }
    
    input[type="text"], input[type="number"], select { background: var(--input-bg); color: var(--text-main); border: 1px solid var(--border); border-radius: 6px; padding: 10px; font-size: 16px; outline: none; width: 100%; box-sizing: border-box; }
    
    #result-text { white-space: pre-wrap; background: var(--bg); padding: 20px; border-radius: 8px; font-size: 15px; border: 1px solid var(--border); color: var(--text-main); }
    .summary-header { background: var(--log-header-bg); border-radius: 8px; padding: 20px; margin-bottom: 15px; display: flex; justify-content: space-between; color: var(--text-main); }

    .stat-container { display: flex; align-items: center; gap: 15px; margin-bottom: 25px; background: var(--stat-bg); border: 2px solid var(--stat-border); border-radius: 12px; padding: 15px; }

    .dark-mode-toggle {
        position: fixed; top: 20px; right: 20px; z-index: 1000;
        padding: 10px 15px; border-radius: 50px; border: none;
        background: var(--primary); color: white; cursor: pointer; font-weight: bold;
    }

    .section-title { font-size: 14px; font-weight: 900; color: #fff; padding: 6px 12px; border-radius: 4px; display: inline-block; margin-bottom: 15px; text-transform: uppercase; }
    .title-blue { background: var(--primary); }
    .title-grey { background: var(--cargo-header); }
    .title-sky { background: #0ea5e9; }
    .total-row { font-weight: bold; color: var(--danger); font-size: 18px; border-top: 2px solid var(--border); margin-top: 10px; padding-top: 10px; }
    
    .profit-box-small { background: var(--profit-bg); border: 2px solid var(--profit-border); border-radius: 12px; padding: 20px; margin-top: auto; }
    .profit-final-val { font-size: 30px; font-weight: 900; color: var(--success); display: block; margin-top: 5px; }
    .adj-input { width: 100%; font-weight: bold; color: var(--success); box-sizing: border-box; }
    .btn-toggle { padding: 8px 12px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text-main); cursor: pointer; border-radius: 6px; font-weight: bold; font-size: 14px; }
    .btn-toggle.active { background: var(--primary); color: white; }

    .btn-pdf {
        position: fixed; bottom: 25px; right: 25px; z-index: 1000;
        padding: 12px 22px; border-radius: 50px; border: none;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        color: white; cursor: pointer; font-weight: 900; font-size: 15px;
        box-shadow: 0 4px 20px rgba(185,28,28,0.45);
        transition: all 0.2s; display: flex; align-items: center; gap: 8px;
    }
    .btn-pdf:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(185,28,28,0.55); }

    @media print {
        body { background: #fff !important; color: #000 !important; padding: 0 !important; }
        .dark-mode-toggle, .btn-pdf, #uploadExcel { display: none !important; }
        .container { box-shadow: none !important; border-radius: 0 !important; padding: 15px !important; max-width: 100% !important; background: #fff !important; }
        .side-panel, .card-mini, .stat-container, .profit-box-small { background: #f9fafb !important; border-color: #e5e7eb !important; }
    }
</style>
